<Window x:Class="CallNotesTray.MainPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CallNotes"
        Width="400" MinWidth="400" MaxWidth="400"
        SizeToContent="Height" MaxHeight="860"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="Manual" ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{StaticResource BrushTextPrimary}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
        ShowInTaskbar="False" Topmost="False">

    <!-- Aussenrahmen: abgerundetes, dunkles Popover mit dezentem Rand/Schatten. -->
    <Border Background="{StaticResource BrushWindowBg}" CornerRadius="14"
            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="828" Padding="0">
            <StackPanel Margin="16,15,16,14" x:Name="RootStack">

                <!-- ==================== Header ==================== -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Source="pack://application:,,,/Assets/app-icon.png"
                           Width="34" Height="34" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="CallNotes" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="HeaderSubtitle" Text="Anruf-Autopilot bereit"
                                   FontSize="12" Foreground="{StaticResource BrushPurple}" Margin="0,1,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="HelpButton" Text="&#xE897;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" Foreground="{StaticResource BrushTextTertiary}"
                                   VerticalAlignment="Center" Cursor="Help"
                                   ToolTip="CallNotes verwandelt Anrufe automatisch in Notizen: Aufnahme, Transkription (lokal via Whisper), Sprecher-Trennung und KI-Zusammenfassung."/>
                        <Ellipse x:Name="DaemonStatusDot" Width="10" Height="10" Margin="10,0,0,0"
                                 Fill="{StaticResource BrushTextTertiary}" VerticalAlignment="Center"
                                 ToolTip="Status des Aufnahme-Daemons"/>
                    </StackPanel>
                </Grid>

                <!-- Leerlauf-Hinweis: erklaert Erstnutzern, WANN etwas passiert
                     (Popup/Aufnahme erst im laufenden Anruf, nicht beim App-Start) -->
                <Border x:Name="IdleHintCard" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource BrushTextTertiary}"
                                   VerticalAlignment="Top" Margin="0,2,8,0"/>
                        <TextBlock x:Name="IdleHintText" TextWrapping="Wrap" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" MaxWidth="330"/>
                    </StackPanel>
                </Border>

                <!-- Live-Mikro-Monitor: welche App nutzt gerade das Mikrofon? Macht auch
                     nicht-gelistete Apps sichtbar (Google Meet/Teams-Web im Browser) und
                     bietet per Klick an, sie dauerhaft aufzunehmen (Windows-Pendant zur
                     Karte in der Mac-Menueleisten-App, SettingsApp.swift). -->
                <Border x:Name="MicMonitorCard" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="MicMonitorGlyph" Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="{StaticResource BrushAccent}"
                                   VerticalAlignment="Top" Margin="0,2,8,0"/>
                        <StackPanel MaxWidth="330">
                            <TextBlock x:Name="MicMonitorText" TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}"/>
                            <TextBlock x:Name="MicMonitorSub" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <Button x:Name="MicMonitorButton" Content="Diese App immer aufnehmen"
                                    Style="{StaticResource PrimaryButton}" Margin="0,8,0,0"
                                    HorizontalAlignment="Left" Visibility="Collapsed"
                                    Click="MicMonitorButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ==================== Aktiver Anruf ==================== -->
                <Border x:Name="ActiveCallCard" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushDanger}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ActiveCallApp" Text="—" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="ActiveCallDuration" Text="00:00" Foreground="{StaticResource BrushTextSecondary}"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>

                        <!-- Wellenform Mikrofon ("Du") -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="62"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="MicLabel" Text="Du" Style="{StaticResource FieldLabel}" FontSize="12"/>
                            <Border Grid.Column="1" Height="30" Background="{StaticResource BrushTrackBg}" CornerRadius="7" ClipToBounds="True">
                                <StackPanel x:Name="MicWavePanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Wellenform System ("Gegenseite") -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="62"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SysLabel" Text="Gegenseite" Style="{StaticResource FieldLabel}" FontSize="12"/>
                            <Border Grid.Column="1" Height="30" Background="{StaticResource BrushTrackBg}" CornerRadius="7" ClipToBounds="True">
                                <StackPanel x:Name="SysWavePanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Teilnehmer-Zeilen (dynamisch) -->
                        <StackPanel x:Name="ParticipantsPanel"/>
                        <DockPanel Margin="0,2,0,0">
                            <Button x:Name="AddParticipantButton" Style="{StaticResource LinkButton}" DockPanel.Dock="Left"
                                    HorizontalAlignment="Left" Click="AddParticipantButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="AddParticipantText" Text="weiterer Teilnehmer" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SaveParticipantsButton" Content="Speichern" Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Right" Click="SaveParticipantsButton_Click"/>
                        </DockPanel>

                        <Border Height="1" Background="{StaticResource BrushBorderSubtle}" Margin="0,12,0,10"/>
                        <Button x:Name="DiscardCallButton" Style="{StaticResource LinkButton}" HorizontalAlignment="Left"
                                Click="DiscardCallButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource BrushDanger}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DiscardCallText" Text="Diesen Anruf nicht aufnehmen" Margin="7,0,0,0"
                                           Foreground="{StaticResource BrushDanger}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ==================== Sprecher-Zuordnung ==================== -->
                <Border x:Name="PendingSection" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel x:Name="PendingList"/>
                    </StackPanel>
                </Border>

                <!-- ==================== Letzte Anrufe ==================== -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="RecentNotesTitle" Text="LETZTE ANRUFE" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="RecentNotesList"/>
                        <TextBlock x:Name="RecentNotesEmpty" Text="Noch keine Notizen."
                                   Foreground="{StaticResource BrushTextSecondary}" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- ==================== Fehlgeschlagene Aufnahmen ==================== -->
                <Border x:Name="FailedSection" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="FailedTitle" Text="FEHLGESCHLAGEN" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="FailedList"/>
                    </StackPanel>
                </Border>

                <!-- ==================== Einstellungen ==================== -->
                <Border Height="1" Background="{StaticResource BrushBorderSubtle}" Margin="2,2,2,12"/>

                <Border x:Name="SettingsHeaderRow" Background="Transparent" Cursor="Hand"
                        MouseLeftButtonUp="SettingsToggle_Click" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SettingsChevron" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SettingsTitle" Text="Einstellungen" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="SettingsBody" Margin="0,12,0,0" Visibility="Collapsed">

                    <!-- Sprache -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock x:Name="LangHeader" Text="SPRACHE" Style="{StaticResource SectionHeader}" Margin="2,0,0,0"/>
                        <TextBlock Style="{StaticResource InfoGlyph}" ToolTip="Sprache der Oberfläche und der Transkription/Notizen."/>
                    </StackPanel>
                    <Border Style="{StaticResource SegmentTrack}" Margin="0,0,0,16">
                        <UniformGrid Rows="1">
                            <RadioButton x:Name="LangSystem" GroupName="lang" Style="{StaticResource Segment}" Content="System" Tag="system"/>
                            <RadioButton x:Name="LangDe" GroupName="lang" Style="{StaticResource Segment}" Content="Deutsch" Tag="de"/>
                            <RadioButton x:Name="LangEn" GroupName="lang" Style="{StaticResource Segment}" Content="English" Tag="en"/>
                        </UniformGrid>
                    </Border>

                    <!-- Speicherorte -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock x:Name="StorageHeader" Text="SPEICHERORTE" Style="{StaticResource SectionHeader}" Margin="2,0,0,0"/>
                        <TextBlock Style="{StaticResource InfoGlyph}" ToolTip="Wohin Notizen und Audio-Archiv geschrieben werden."/>
                    </StackPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="NotesDirLabel" Grid.Column="0" Text="Notizen" Style="{StaticResource FieldLabel}" Width="88"/>
                        <TextBlock x:Name="NotesDirValue" Grid.Column="1" Text="—" Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                        <Button x:Name="BrowseNotesButton" Grid.Column="2" Content="wählen…" Style="{StaticResource ChooseButton}" Click="BrowseNotesButton_Click"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="AudioDirLabel" Grid.Column="0" Text="Audio-Archiv" Style="{StaticResource FieldLabel}" Width="88"/>
                        <TextBlock x:Name="AudioDirValue" Grid.Column="1" Text="—" Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                        <Button x:Name="BrowseAudioButton" Grid.Column="2" Content="wählen…" Style="{StaticResource ChooseButton}" Click="BrowseAudioButton_Click"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MirrorDirLabel" Grid.Column="0" Text="Kopie (extern)" Style="{StaticResource FieldLabel}" Width="88"/>
                        <TextBlock x:Name="MirrorDirValue" Grid.Column="1" Text="—" Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                        <Button x:Name="MirrorToggleButton" Grid.Column="2" Content="aus" Style="{StaticResource ChooseButton}" Margin="0,0,6,0" Click="MirrorToggleButton_Click"/>
                        <Button x:Name="BrowseMirrorButton" Grid.Column="3" Content="wählen…" Style="{StaticResource ChooseButton}" Click="BrowseMirrorButton_Click"/>
                    </Grid>

                    <!-- Transkription -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock x:Name="TranscriptionHeader" Text="TRANSKRIPTION" Style="{StaticResource SectionHeader}" Margin="2,0,0,0"/>
                        <TextBlock Style="{StaticResource InfoGlyph}" ToolTip="Lokal (Whisper) läuft offline auf diesem Gerät. Groq ist eine schnelle Cloud-API. Parakeet ist ein schnelles lokales Modell (sherpa-onnx)."/>
                    </StackPanel>
                    <Border Style="{StaticResource SegmentTrack}" Margin="0,0,0,8">
                        <UniformGrid Rows="1">
                            <RadioButton x:Name="TransLocal" GroupName="trans" Style="{StaticResource Segment}" Content="Lokal (Whisper)" Tag="local" Checked="TransSegment_Changed"/>
                            <RadioButton x:Name="TransGroq" GroupName="trans" Style="{StaticResource Segment}" Content="Groq (Cloud)" Tag="groq" Checked="TransSegment_Changed"/>
                            <RadioButton x:Name="TransParakeet" GroupName="trans" Style="{StaticResource Segment}" Content="Parakeet" Tag="parakeet" Checked="TransSegment_Changed"/>
                        </UniformGrid>
                    </Border>
                    <StackPanel x:Name="GroqKeyRow" Visibility="Collapsed" Margin="0,0,0,16">
                        <TextBlock x:Name="GroqKeyLabel" Text="Groq API-Key" Style="{StaticResource FieldLabel}" Margin="2,0,0,4"/>
                        <TextBox x:Name="GroqKeyInput"/>
                    </StackPanel>
                    <Border x:Name="TransSpacer" Height="8" Margin="0,0,0,8"/>

                    <!-- KI-Zusammenfassung -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock x:Name="SummaryHeader" Text="KI-ZUSAMMENFASSUNG" Style="{StaticResource SectionHeader}" Margin="2,0,0,0"/>
                        <TextBlock Style="{StaticResource InfoGlyph}" ToolTip="Erzeugt Kurzfassung/To-dos aus dem Transkript. Claude Code nutzt die lokale CLI. „Eigene KI“ spricht jede OpenAI-kompatible API an. „Aus“ = nur Transkript."/>
                    </StackPanel>
                    <Border Style="{StaticResource SegmentTrack}" Margin="0,0,0,8">
                        <UniformGrid Rows="1">
                            <RadioButton x:Name="SumClaude" GroupName="sum" Style="{StaticResource Segment}" Content="Claude Code" Tag="claude" Checked="SumSegment_Changed"/>
                            <RadioButton x:Name="SumOpenAI" GroupName="sum" Style="{StaticResource Segment}" Content="Eigene KI" Tag="openai" Checked="SumSegment_Changed"/>
                            <RadioButton x:Name="SumOff" GroupName="sum" Style="{StaticResource Segment}" Content="Aus" Tag="off" Checked="SumSegment_Changed"/>
                        </UniformGrid>
                    </Border>
                    <StackPanel x:Name="OpenAiRow" Visibility="Collapsed" Margin="0,0,0,16">
                        <TextBlock Text="API-URL" Style="{StaticResource FieldLabel}" Margin="2,0,0,4"/>
                        <TextBox x:Name="SummarizerUrlInput" Margin="0,0,0,6"/>
                        <TextBlock Text="Modell" Style="{StaticResource FieldLabel}" Margin="2,0,0,4"/>
                        <TextBox x:Name="SummarizerModelInput" Margin="0,0,0,6"/>
                        <TextBlock Text="API-Key" Style="{StaticResource FieldLabel}" Margin="2,0,0,4"/>
                        <TextBox x:Name="SummarizerApiKeyInput"/>
                    </StackPanel>
                    <Border x:Name="SumSpacer" Height="8" Margin="0,0,0,8"/>

                    <!-- Notiz-Inhalte -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                        <TextBlock x:Name="NoteContentHeader" Text="NOTIZ-INHALTE" Style="{StaticResource SectionHeader}" Margin="2,0,0,0"/>
                        <TextBlock Style="{StaticResource InfoGlyph}" ToolTip="Welche Abschnitte die KI in die Notiz schreibt."/>
                    </StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="ChkKurzfassung" Grid.Row="0" Grid.Column="0" Style="{StaticResource MacCheckBox}" Content="Kurzfassung" Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkBesprochen" Grid.Row="0" Grid.Column="1" Style="{StaticResource MacCheckBox}" Content="Besprochen" Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkTodos" Grid.Row="1" Grid.Column="0" Style="{StaticResource MacCheckBox}" Content="To-dos"/>
                        <CheckBox x:Name="ChkFollowup" Grid.Row="1" Grid.Column="1" Style="{StaticResource MacCheckBox}" Content="Follow-up-Mail"/>
                    </Grid>

                    <!-- Ablage zusätzlich in -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                        <TextBlock x:Name="DestHeader" Text="ABLAGE ZUSÄTZLICH IN" Style="{StaticResource SectionHeader}" Margin="2,0,0,0"/>
                        <TextBlock Style="{StaticResource InfoGlyph}" ToolTip="Notiz zusätzlich an einen Cloud-Dienst schicken. (Apple Notes gibt es nur auf macOS.)"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkNextcloud" Style="{StaticResource MacCheckBox}" Content="Nextcloud" Margin="0,0,0,8" Checked="DestCheck_Changed" Unchecked="DestCheck_Changed"/>
                    <StackPanel x:Name="NextcloudRow" Visibility="Collapsed" Margin="27,0,0,8">
                        <TextBox x:Name="NextcloudUrlInput" Margin="0,0,0,6" Tag="Nextcloud-URL"/>
                        <TextBox x:Name="NextcloudUserInput" Margin="0,0,0,6" Tag="Benutzer"/>
                        <TextBox x:Name="NextcloudPassInput" Tag="App-Passwort"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkNotion" Style="{StaticResource MacCheckBox}" Content="Notion" Margin="0,0,0,8" Checked="DestCheck_Changed" Unchecked="DestCheck_Changed"/>
                    <StackPanel x:Name="NotionRow" Visibility="Collapsed" Margin="27,0,0,8">
                        <TextBox x:Name="NotionTokenInput" Margin="0,0,0,6" Tag="Notion-Token"/>
                        <TextBox x:Name="NotionParentInput" Tag="Seiten-ID"/>
                    </StackPanel>

                    <!-- Push -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,7">
                        <TextBlock x:Name="PushHeader" Text="PUSH" Style="{StaticResource SectionHeader}" Margin="2,0,0,0"/>
                        <TextBlock Style="{StaticResource InfoGlyph}" ToolTip="Optional: ntfy.sh-URL für eine Push-Benachrichtigung, wenn eine Notiz fertig ist."/>
                    </StackPanel>
                    <TextBox x:Name="NtfyInput" Margin="0,0,0,16"/>

                    <!-- Aktionen -->
                    <DockPanel Margin="0,0,0,2">
                        <Button x:Name="SyncNowButton" Content="Jetzt syncen" Style="{StaticResource PrimaryButton}" DockPanel.Dock="Left"
                                HorizontalAlignment="Left" Click="SyncNowButton_Click"/>
                        <Button x:Name="SaveSettingsButton" Content="Speichern &amp; Neustart" Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Right" Click="SaveSettingsButton_Click"/>
                    </DockPanel>
                    <TextBlock x:Name="SettingsSavedHint" Text="" FontSize="11.5" Foreground="{StaticResource BrushSuccess}"
                               Margin="0,8,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>

                <!-- ==================== Beenden ==================== -->
                <DockPanel Margin="0,12,0,0">
                    <Button x:Name="QuitButton" Content="Beenden" Style="{StaticResource LinkButton}"
                            DockPanel.Dock="Right" HorizontalAlignment="Right" Click="QuitButton_Click"/>
                </DockPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
